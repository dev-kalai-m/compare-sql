<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>cmp-sql · {{ name }}</title>
  <style>
    :root {
      --bg: #0e1116; --fg: #e5e7eb; --muted: #9ca3af; --panel: #151a21;
      --add: #103a1e; --del: #3a1114; --addfg: #7ee787; --delfg: #ff7b72;
      --major: #ff7b72; --minor: #e3b341; --cosmetic: #8b949e;
    }
    * { box-sizing: border-box; }
    body { margin: 0; font-family: ui-monospace, Menlo, Consolas, monospace;
           background: var(--bg); color: var(--fg); font-size: 13px; }
    header { padding: 12px 20px; border-bottom: 1px solid #222; background: var(--panel); }
    header h1 { margin: 0 0 6px; font-size: 16px; }
    .meta { color: var(--muted); font-size: 12px; }
    .chip { display: inline-block; padding: 2px 8px; border-radius: 10px;
            font-size: 11px; margin-left: 8px; }
    .chip.identical        { background: #1a2e1c; color: #7ee787; }
    .chip.normalized_match { background: #1a2a3a; color: #79c0ff; }
    .chip.semantic_match   { background: #2a2140; color: #d2a8ff; }
    .chip.different        { background: #3a1a1a; color: #ff7b72; }
    .chip.parse_error_src, .chip.parse_error_tgt, .chip.parse_error_both,
    .chip.missing_src, .chip.missing_tgt, .chip.timeout {
      background: #3a2a14; color: #e3b341;
    }

    .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: #222; }
    .pane { background: var(--panel); padding: 12px 16px; overflow-x: auto; }
    .pane h2 { margin: 0 0 8px; font-size: 13px; color: var(--muted); }
    pre { margin: 0; white-space: pre; tab-size: 2; }

    .diff pre span.add { background: var(--add); color: var(--addfg); display: block; }
    .diff pre span.del { background: var(--del); color: var(--delfg); display: block; }
    .diff pre span.ctx { color: var(--fg); display: block; }

    .edits { padding: 16px 20px; border-top: 1px solid #222; }
    .edits h2 { font-size: 13px; color: var(--muted); margin: 0 0 8px; }
    .edit { padding: 4px 0; border-bottom: 1px dotted #222; }
    .sev { display: inline-block; width: 72px; font-size: 11px; }
    .sev.major    { color: var(--major); }
    .sev.minor    { color: var(--minor); }
    .sev.cosmetic { color: var(--cosmetic); }
    .path { color: var(--muted); margin-right: 8px; }
  </style>
</head>
<body>
  <header>
    <h1>{{ name }}
      <span class="chip {{ status }}">{{ status }}</span>
    </h1>
    <div class="meta">
      edits:
      <strong>{{ edits.major }}</strong> major ·
      <strong>{{ edits.minor }}</strong> minor ·
      <strong>{{ edits.cosmetic }}</strong> cosmetic
      {% if text_fallback %} · <em>text-fallback used</em>{% endif %}
      {% if parse_error_src %} · src parse error: {{ parse_error_src }}{% endif %}
      {% if parse_error_tgt %} · tgt parse error: {{ parse_error_tgt }}{% endif %}
    </div>
  </header>

  <section class="grid">
    <div class="pane"><h2>assets/code_sql/{{ name }}</h2><pre>{{ src_html|safe }}</pre></div>
    <div class="pane"><h2>assets/db_sql/{{ name }}</h2><pre>{{ tgt_html|safe }}</pre></div>
  </section>

  <section class="pane diff">
    <h2>Unified diff (normalized)</h2>
    <pre>{{ unified_html|safe }}</pre>
  </section>

  {% if classified %}
  <section class="edits">
    <h2>Structured edits</h2>
    {% for e in classified %}
    <div class="edit">
      <span class="sev {{ e.severity }}">{{ e.severity }}</span>
      <span class="path">{{ e.path }}</span>
      <strong>{{ e.kind }}</strong>
      — {{ e.summary }}
    </div>
    {% endfor %}
  </section>
  {% endif %}
</body>
</html>
